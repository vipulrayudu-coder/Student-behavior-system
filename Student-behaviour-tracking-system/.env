PORT=3000

# JWT Secret - change this to a long random string in production
JWT_SECRET=your_super_secret_key_here

# WhatsApp API Key
WHATSAPP_API_KEY=your_whatsapp_api_key_here

# External API Keys
EXTERNAL_API_KEY_1=your_first_external_api_key
EXTERNAL_API_KEY_2=your_second_external_api_key

# Database type: json (default), mongodb, sqlite
DB_TYPE=json
